// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: products
// Fields:
//   - name: string (required)
//   - price: number (required)
//   - category: string (required)
//   - image: string (required)
//   - description: string
//   - features: list
//   - rating: number
//   - reviews: number
//   - createdAt: timestamp
//
// Collection: orders
// Fields:
//   - userId: string (required)
//   - customerName: string (required)
//   - customerEmail: string (required)
//   - items: list (required)
//   - total: number (required)
//   - status: string (required)
//   - paymentMethod: string (required)
//   - shippingAddress: string (required)
//   - pincode: string (required)
//   - phone: string (required)
//   - createdAt: timestamp
//
// Collection: users
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - role: string (required)
//   - createdAt: timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dhruvidhameliya01@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "dhameliyaheet201@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price > 0 &&
             data.category in ['Anime', 'Coding', 'Memes', 'Quotes', 'Aesthetic'] &&
             data.image is string && data.image.size() > 0;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.customerEmail is string && data.customerEmail.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total > 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered'] &&
             data.paymentMethod in ['UPI', 'Card', 'COD'] &&
             data.shippingAddress is string && data.shippingAddress.size() > 0 &&
             data.pincode is string && data.pincode.size() == 6 &&
             data.phone is string && data.phone.size() > 0;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'user'];
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }
  }
}
