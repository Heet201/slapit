{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A sticker product available in the shop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Anime", "Coding", "Memes", "Quotes", "Aesthetic"] },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "paymentMethod": { "type": "string", "enum": ["UPI", "Card", "COD"] },
        "shippingAddress": { "type": "string" },
        "pincode": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerName", "items", "total", "shippingAddress", "phone"]
    },
    "User": {
      "title": "User",
      "description": "A user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category with a background image.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "image"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Collection of sticker products."
    },
    "/orders": {
      "schema": "Order",
      "description": "Collection of customer orders."
    },
    "/users": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/categories": {
      "schema": "Category",
      "description": "Collection of product categories."
    }
  }
}
